# === IA PARA ANÁLISE (escolha uma) ===
# OpenAI (GPT) - use se tiver saldo no OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude) - use se tiver saldo na Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# === YOUTUBE ===
# Obtenha em: https://console.cloud.google.com -> APIs -> YouTube Data API v3
YOUTUBE_API_KEY=AIza...

# === INSTAGRAM / META ===
# Requires: Facebook Business Account + Meta for Developers App
# https://developers.facebook.com -> My Apps -> Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=EAA...
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841...

# === TIKTOK ===
# Requires: TikTok for Developers account - Research API access
# https://developers.tiktok.com
TIKTOK_CLIENT_KEY=aw...
TIKTOK_CLIENT_SECRET=...

# === LINKEDIN ===
# Requires: LinkedIn Developer App with r_organization_social permission
# https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=AQX...
LINKEDIN_ORGANIZATION_ID=12345678

# === CONFIGURAÇÕES GERAIS ===
# Nicho/palavras-chave para monitorar (separados por vírgula)
KEYWORDS=marketing digital,empreendedorismo,copywriting,vendas,growth hacking

# Período de busca em dias (padrão: 7)
LOOKBACK_DAYS=7

# Mínimo de views/likes para considerar viral
YOUTUBE_MIN_VIEWS=50000
INSTAGRAM_MIN_LIKES=1000
TIKTOK_MIN_VIEWS=100000
LINKEDIN_MIN_REACTIONS=500

# Horário de execução diária (formato HH:MM)
DAILY_RUN_TIME=08:00

# Idioma da análise (pt-BR, en-US)
ANALYSIS_LANGUAGE=pt-BR
